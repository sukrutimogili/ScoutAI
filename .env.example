# ─────────────────────────────────────────────────────────────────────────────
# ScoutAI — Environment Variables
# Copy this file to .env and fill in real values.
# .env is excluded from git — NEVER commit real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Model Provider API Keys ───────────────────────────────────────────────────
# Google Gemini (primary model for both roles in default config)
GOOGLE_API_KEY=your_google_api_key_here

# Groq (fallback model)
GROQ_API_KEY=your_groq_api_key_here

# ── Optional: Google Calendar (S10 scheduling) ────────────────────────────────
# Path to Google service account credentials JSON, or inline JSON string.
# Only required if scheduling.backend = "google_calendar" in config.yaml.
# GOOGLE_CALENDAR_CREDENTIALS_JSON=/path/to/credentials.json

# ── Optional: LangSmith tracing ───────────────────────────────────────────────
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your_langsmith_api_key_here
# LANGCHAIN_PROJECT=scoutai
